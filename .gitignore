# DailyLife Root Gitignore

# Antigravity/Agent metadata
.agent/

# MacOS
.DS_Store

# IDEs
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Flutter/Dart (DailyLife App)
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
coverage/
.metadata

# Android artifacts
android/app/debug
android/app/profile
android/app/release
android/local.properties


# iOS artifacts
ios/Flutter/.last_build_id
ios/Flutter/Ephemeral/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh

# Logs and class files
*.log
*.class

# Miscellaneous
.env
*.swp
*.bak

# Stitch local metadata (if any)
stitch.json
# is currently under version control as a source of truth for Project ID, 
# but if it contains credentials (it doesn't here) it should be ignored. 
# Keep it for now.